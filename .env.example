# ===========================================
# AI 答题接口 - 环境变量配置
# ===========================================

# [必填] OpenAI 兼容 API 的密钥
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# [可选] API Base URL，默认为 OpenAI 官方地址
# 如果使用第三方兼容服务（如 DeepSeek、通义千问、本地 Ollama 等），请修改此项
# DeepSeek:    https://api.deepseek.com/v1
# 通义千问:    https://dashscope.aliyuncs.com/compatible-mode/v1
# Ollama本地:  http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# [可选] 模型名称，默认为 gpt-4o-mini
# DeepSeek:    deepseek-chat
# 通义千问:    qwen-plus
OPENAI_MODEL=gpt-4o-mini

# [可选] 接口访问 token，留空则不校验
# 设置后，请求时需要带上 ?token=xxx 才能访问
API_TOKEN=

# [可选] 多模型并行配置，使用 JSON 数组
# 不配置时，默认使用上面的 OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL 单模型模式
# role 可选：answer | judge
# answer: 参与生成候选答案
# judge:  当候选答案冲突时负责裁决，未设置 judge 时会使用第一个 answer 模型
#
# 示例：
# OPENAI_PROVIDERS=[
#   {"name":"deepseek","baseUrl":"https://api.deepseek.com/v1","apiKey":"sk-xxx","model":"deepseek-chat","role":"answer"},
#   {"name":"openai","baseUrl":"https://api.openai.com/v1","apiKey":"sk-xxx","model":"gpt-4o-mini","role":"answer"},
#   {"name":"judge","baseUrl":"https://api.openai.com/v1","apiKey":"sk-xxx","model":"gpt-4o-mini","role":"judge"}
# ]
OPENAI_PROVIDERS=

# [可选] 答题模式
# consensus: 多模型投票，结果更稳但更慢
# fast: 只要第一个模型返回有效答案就立即返回，更快
ANSWER_MODE=consensus

# [可选] 内存缓存 TTL，单位秒
# 相同题目在短时间内重复请求时可直接返回缓存结果
ANSWER_CACHE_TTL_SECONDS=3600

# [可选] 内存缓存最大条目数
ANSWER_CACHE_MAX_ENTRIES=500

# [可选] 限流开关
RATE_LIMIT_ENABLED=true

# [可选] 限流窗口时长，单位秒
RATE_LIMIT_WINDOW_SECONDS=60

# [可选] 每个 IP 在窗口期内的最大请求数
RATE_LIMIT_MAX_REQUESTS=30

# [可选] 入参长度限制
MAX_TITLE_CHARS=500
MAX_OPTIONS_CHARS=4000
MAX_TOTAL_CHARS=5000

# [可选] POST JSON 请求体最大字符数
MAX_BODY_CHARS=20000
